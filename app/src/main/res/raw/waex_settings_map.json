{
  "categories": [
    {
      "id": "general",
      "title": "General",
      "summary": "Anti-revoke, chats, limits",
      "icon": "ic_general",
      "sub_screens": [
        {
          "id": "general_main",
          "title": "General",
          "prefs": [
            { "key": "anti_revoke",            "type": "switch", "default_bool": false, "title": "Anti-Revoke Messages",     "summary": "Prevent others from deleting their messages for you", "tags": ["anti revoke","delete","deleted"] },
            { "key": "show_revoked_indicator", "type": "switch", "default_bool": true,  "title": "Show Revoked Indicator",   "summary": "Show a marker on revoked messages",  "dep": "anti_revoke" },
            { "key": "anti_revoke_groups",     "type": "switch", "default_bool": false, "title": "Anti-Revoke in Groups",    "summary": "Also prevent deletion in groups",     "dep": "anti_revoke" },
            { "key": "anti_revoke_status",     "type": "switch", "default_bool": false, "title": "Anti-Revoke Status",       "summary": "Prevent status revocation",           "dep": "anti_revoke" },
            { "key": "recover_delete_for_me",  "type": "switch", "default_bool": false, "title": "Recover Delete for Me",    "summary": "Recover messages you deleted for yourself", "tags": ["recover","delete for me"] },
            { "key": "show_edit_message",      "type": "switch", "default_bool": false, "title": "Show Edited Messages",     "summary": "View original text before edits",    "tags": ["edit","edited message"] },
            { "key": "new_chat",               "type": "switch", "default_bool": false, "title": "New Chat Enhancements",    "summary": "Improved new chat flow",             "tags": ["new chat"] },
            { "key": "call_type",              "type": "list",   "default_str":  "0",   "title": "Default Call Type",        "summary": "Choose voice or video as default",   "dep": "new_chat", "entries": ["Voice","Video"], "entry_values": ["0","1"] },
            { "key": "shareable_limit",        "type": "switch", "default_bool": false, "title": "Share Limit Bypass",       "summary": "Share to unlimited contacts at once", "tags": ["share limit","forward"] },
            { "key": "pinned_limit",           "type": "switch", "default_bool": false, "title": "Pinned Chat Limit Bypass", "summary": "Pin unlimited chats",                "tags": ["pin limit"] },
            { "key": "delete_status",          "type": "switch", "default_bool": false, "title": "Delete Status Option",     "summary": "Add delete button in status viewer",  "tags": ["delete status"] },
            { "key": "lite_mode",              "type": "switch", "default_bool": false, "title": "Lite Mode",                "summary": "Reduce animations for better performance", "tags": ["lite","performance"] },
            { "key": "lite_mode_folder",       "type": "file",   "default_str":  "",    "title": "Lite Mode Folder",         "summary": "Select a folder for lite mode",      "dep": "lite_mode" }
          ]
        },
        {
          "id": "general_home",
          "title": "Home Screen",
          "prefs": [
            { "key": "floating_bottom_bar", "type": "switch", "default_bool": false,    "title": "Floating Bottom Bar",     "summary": "Replace default navigation with floating bar",    "tags": ["bottom bar","fab"] },
            { "key": "filter_groups",       "type": "switch", "default_bool": false,    "title": "Separate Groups Tab",     "summary": "Move groups to a dedicated tab",                  "tags": ["groups tab","separate groups"] },
            { "key": "ig_status",           "type": "switch", "default_bool": false,    "title": "Instagram-Style Status",  "summary": "Display contacts status as story rings",           "tags": ["ig status","instagram"] },
            { "key": "show_online",         "type": "switch", "default_bool": false,    "title": "Show Online Indicator",   "summary": "Show green dot on online contacts",                "tags": ["online","online dot"] },
            { "key": "menu_home",           "type": "switch", "default_bool": false,    "title": "Custom Home Menu Items",  "summary": "Add extra items to the home toolbar",             "tags": ["menu","toolbar menu"] },
            { "key": "hidetabs",            "type": "multi",  "default_str":  "",       "title": "Hide Tabs",               "summary": "Choose which tabs to hide on home screen",         "tags": ["hide tabs"], "entries": ["Chats","Status","Communities","Calls"], "entry_values": ["0","1","2","3"] },
            { "key": "animation_list",      "type": "list",   "default_str":  "default","title": "List Animation",          "summary": "Animation style for chat list",                   "tags": ["animation"], "entries": ["Default","Slide","Fade","None"], "entry_values": ["default","slide","fade","none"] }
          ]
        },
        {
          "id": "general_conversation",
          "title": "Conversation",
          "prefs": [
            { "key": "customforwardlimit",            "type": "text",   "default_str":  "",    "title": "Custom Forward Limit",       "summary": "Max contacts for forwarding messages",  "tags": ["forward limit"] },
            { "key": "filter_group_members_messages", "type": "switch", "default_bool": false, "title": "Filter Group Messages",      "summary": "Show only messages from specific members", "tags": ["filter group"] },
            { "key": "seentick",                      "type": "list",   "default_str":  "0",   "title": "Blue Tick Button",           "summary": "Add manual blue tick send button",      "tags": ["seen tick","blue tick"], "entries": ["Disabled","In Text Toolbar","In Reply"], "entry_values": ["0","1","2"] },
            { "key": "chat_scroll_button",            "type": "switch", "default_bool": false, "title": "Chat Scroll Buttons",        "summary": "Show up/down scroll buttons in chat",   "tags": ["scroll button"] },
            { "key": "custom_time",                   "type": "switch", "default_bool": false, "title": "Custom Time Format",         "summary": "Override timestamp display format",    "tags": ["time format"] },
            { "key": "video_note_attachment",         "type": "switch", "default_bool": false, "title": "Video Note in Attachments",  "summary": "Add video note option to attachment picker", "tags": ["video note"] },
            { "key": "tag_message",                   "type": "switch", "default_bool": false, "title": "Tag Message Feature",        "summary": "Tag and pin messages in chats",         "tags": ["tag","mention"] },
            { "key": "group_admin_tools",             "type": "switch", "default_bool": false, "title": "Group Admin Tools",          "summary": "Extra tools for group administrators",  "tags": ["admin","group tools"] },
            { "key": "stickers_pack",                 "type": "switch", "default_bool": false, "title": "Sticker Enhancements",       "summary": "Improved sticker browsing and sending", "tags": ["stickers"] },
            { "key": "copy_status_text",              "type": "switch", "default_bool": false, "title": "Copy Status Text",           "summary": "Allow copying text from status updates","tags": ["copy status"] },
            { "key": "google_translate",              "type": "switch", "default_bool": false, "title": "Google Translate in Chat",   "summary": "Translate messages with a long press",  "tags": ["translate"] },
            { "key": "audio_transcript",              "type": "switch", "default_bool": false, "title": "Audio Transcript",           "summary": "Transcribe voice messages to text",     "tags": ["transcript","audio to text"] }
          ]
        }
      ]
    },
    {
      "id": "privacy",
      "title": "Privacy",
      "summary": "Last seen, typing, ghost mode",
      "icon": "ic_privacy",
      "sub_screens": [
        {
          "id": "privacy_main",
          "title": "Privacy",
          "prefs": [
            { "key": "freezelastseen",              "type": "switch", "default_bool": false, "title": "Freeze Last Seen",             "summary": "Stop updating your last seen timestamp",     "tags": ["last seen","freeze"] },
            { "key": "hideread",                    "type": "switch", "default_bool": false, "title": "Hide Blue Ticks",              "summary": "Do not send blue read receipts",              "tags": ["hide read","blue tick","read receipt"] },
            { "key": "hide_seen_view",              "type": "switch", "default_bool": false, "title": "Hide Seen on View",            "summary": "Mark as seen only on deliberate action",     "dep": "hideread" },
            { "key": "blueonreply",                 "type": "switch", "default_bool": false, "title": "Blue Tick on Reply Only",      "summary": "Show blue tick only when you reply",         "dep": "hideread" },
            { "key": "hideread_group",              "type": "switch", "default_bool": false, "title": "Hide Blue Ticks in Groups",    "summary": "Suppress group read receipts",               "tags": ["group read"] },
            { "key": "hidereceipt",                 "type": "switch", "default_bool": false, "title": "Hide Delivery Receipt",        "summary": "Stop sending delivery receipts",             "tags": ["delivery receipt"] },
            { "key": "ghostmode_t",                 "type": "switch", "default_bool": false, "title": "Hide Typing Indicator",        "summary": "Do not broadcast typing status",             "tags": ["ghost mode","typing"] },
            { "key": "ghostmode_r",                 "type": "switch", "default_bool": false, "title": "Hide Recording Indicator",     "summary": "Do not broadcast recording status",          "tags": ["ghost recording","recording"] },
            { "key": "hideonceseen",                "type": "switch", "default_bool": false, "title": "Hide View Once Seen",          "summary": "Mark view-once seen silently",               "tags": ["view once"] },
            { "key": "hideaudioseen",               "type": "switch", "default_bool": false, "title": "Hide Audio Seen",              "summary": "Do not send audio listened receipt",        "tags": ["audio seen"] },
            { "key": "viewonce",                    "type": "switch", "default_bool": false, "title": "Save View Once Media",         "summary": "Save view-once photos and videos",           "tags": ["view once save"] },
            { "key": "hidestatusview",              "type": "switch", "default_bool": false, "title": "Hide Status Viewed",           "summary": "Watch status without marking viewed",        "tags": ["status view"] },
            { "key": "custom_privacy_type",         "type": "list",   "default_str":  "0",   "title": "Per-Contact Custom Privacy",   "summary": "Set privacy rules per contact",              "tags": ["custom privacy","per contact"], "entries": ["Disabled","Whitelist","Blacklist"], "entry_values": ["0","1","2"] },
            { "key": "open_deleted_messages",       "type": "action", "title": "Deleted Messages Viewer",      "summary": "Browse anti-revoked messages",               "tags": ["deleted messages"] },
            { "key": "always_typing_global",        "type": "switch", "default_bool": false, "title": "Always Typing Simulation",     "summary": "Simulate typing to selected contacts",       "tags": ["always typing","typing simulation"] },
            { "key": "always_typing_global_target", "type": "list",   "default_str":  "1",   "title": "Typing Simulation Target",     "summary": "Who to simulate typing for",                 "dep": "always_typing_global", "entries": ["All Contacts","Specific Contacts"], "entry_values": ["0","1"] },
            { "key": "always_typing_global_mode",   "type": "list",   "default_str":  "1",   "title": "Typing Simulation Mode",       "summary": "How typing is simulated",                    "dep": "always_typing_global", "entries": ["Conversation Mode","Global Mode"], "entry_values": ["1","2"] },
            { "key": "dnd_mode",                    "type": "switch", "default_bool": false, "title": "DND Mode",                     "summary": "Block all incoming messages temporarily",    "tags": ["dnd","do not disturb"] },
            { "key": "anti_wa",                     "type": "switch", "default_bool": false, "title": "Anti-WA (Block Tracking)",     "summary": "Block WhatsApp telemetry",                   "tags": ["anti wa","tracking"] },
            { "key": "hide_chat",                   "type": "switch", "default_bool": false, "title": "Hide Chats",                   "summary": "Hide specific chats from list",              "tags": ["hide chat"] },
            { "key": "locked_chats_enhancer",       "type": "switch", "default_bool": false, "title": "Locked Chats Enhancer",        "summary": "Improve locked chat experience",             "tags": ["locked chat"] },
            { "key": "call_privacy",                "type": "switch", "default_bool": false, "title": "Call Privacy",                 "summary": "Control who can call you",                   "tags": ["call privacy","block calls"] }
          ]
        }
      ]
    },
