<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Drag Handle -->
    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Title -->
            <TextView
                android:id="@+id/picker_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose Color"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="20dp" />

            <!-- Presets Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Presets"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="10dp" />

            <!-- Presets Grid: 2 rows × 6 circles -->
            <GridLayout
                android:id="@+id/presets_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="6"
                android:rowCount="2"
                android:layout_marginBottom="24dp"
                android:alignmentMode="alignBounds"
                android:columnOrderPreserved="false" />

            <!-- Custom Color Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom Color"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="10dp" />

            <!-- Preview + Hex Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/color_preview"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="16dp"
                    android:background="@android:color/black" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hex Code (#RRGGBB)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/hex_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:maxLength="7"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Hue Label -->
            <TextView
                android:id="@+id/hue_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hue"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="4dp" />

            <!-- Hue SeekBar (rainbow gradient applied programmatically) -->
            <SeekBar
                android:id="@+id/hue_seekbar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:max="360"
                android:progress="0"
                android:thumbTint="?attr/colorOnSurface"
                android:layout_marginBottom="16dp" />

            <!-- Brightness Label -->
            <TextView
                android:id="@+id/brightness_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Brightness"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="4dp" />

            <!-- Brightness SeekBar (gradient applied programmatically) -->
            <SeekBar
                android:id="@+id/brightness_seekbar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:max="100"
                android:progress="100"
                android:thumbTint="?attr/colorOnSurface"
                android:layout_marginBottom="24dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_color"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_color"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
