    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradlew: installWhatsappDebug",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":app:installWhatsappDebug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "gradlew: assembleWhatsappDebug",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":app:assembleWhatsappDebug"
            ],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "gradlew: assembleWhatsappRelease",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":app:assembleWhatsappRelease"
            ],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
