        {
            "label": "gradlew: installWhatsappRelease",
            "type": "shell",
            "command": "./gradlew",
            "args": [
                ":app:installWhatsappRelease"
            ],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "ADB: Stream Logcat (App Package)",
            "type": "shell",
            "command": "adb logcat --package=com.waenhancer",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
