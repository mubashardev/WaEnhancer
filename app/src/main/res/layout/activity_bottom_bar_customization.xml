<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="?attr/colorOnSurface"
            app:titleCentered="true"
            app:titleTextAppearance="?attr/textAppearanceTitleMedium"
            app:titleTextColor="?attr/colorOnSurface" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.4"
            android:background="?attr/colorOutlineVariant" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Sliders & Switched Settings (Scrollable) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Main Floating Navigation Toggle Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/floating_bottom_bar"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/floating_bottom_bar_sum"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?android:attr/textColorSecondary" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_floating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Customization Controls (Visible only when floating is enabled) -->
                <LinearLayout
                    android:id="@+id/layout_customization_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Pill Design Category -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/floating_bottom_bar_pill_design"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textStyle="bold" />

                            <RadioGroup
                                android:id="@+id/pill_design_group"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <RadioButton
                                    android:id="@+id/radio_design_regular"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Classic (Regular)" />

                                <RadioButton
                                    android:id="@+id/radio_design_pro"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Refined (Pro)" />

                                <RadioButton
                                    android:id="@+id/radio_design_ios_glass"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.2"
                                    android:text="iOS Glass (Pro)" />
                            </RadioGroup>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Scroll Hide Category -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Hide on Scroll Switch -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/floating_bottom_bar_scroll_hide"
                                        android:textAppearance="?attr/textAppearanceTitleMedium"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/floating_bottom_bar_scroll_hide_sum"
                                        android:textAppearance="?attr/textAppearanceBodySmall"
                                        android:textColor="?android:attr/textColorSecondary" />
                                </LinearLayout>

                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/switch_scroll_hide"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <!-- Scroll Hide Style Options -->
                            <LinearLayout
                                android:id="@+id/layout_scroll_hide_mode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="vertical">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginBottom="12dp"
                                    android:background="?attr/colorOutlineVariant" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/floating_bottom_bar_scroll_hide_mode"
                                    android:textAppearance="?attr/textAppearanceTitleSmall"
                                    android:textStyle="bold" />

                                <RadioGroup
                                    android:id="@+id/scroll_hide_mode_group"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:orientation="horizontal">

                                    <RadioButton
                                        android:id="@+id/radio_hide_downward"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/scroll_hide_downward" />

                                    <RadioButton
                                        android:id="@+id/radio_hide_invisible"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/scroll_hide_invisible" />
                                </RadioGroup>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Color & Glass switches -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                        <!-- Glassmorphism Switch -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/floating_bottom_bar_glass"
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/floating_bottom_bar_glass_sum"
                                    android:textAppearance="?attr/textAppearanceBodySmall"
                                    android:textColor="?android:attr/textColorSecondary" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_glass"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <!-- Color Picker Button -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="12dp"
                            android:background="?attr/colorOutlineVariant" />

                        <LinearLayout
                            android:id="@+id/btn_select_color"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/floating_bottom_bar_fill_color"
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_color"
                                    android:textAppearance="?attr/textAppearanceBodySmall"
                                    android:textColor="?android:attr/textColorSecondary" />
                            </LinearLayout>

                            <View
                                android:id="@+id/color_preview_circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/pref_seekbar_value_bg" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sliders for margins, radius, opacity -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Corner Radius Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/floating_bottom_bar_radius"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_radius"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0"
                                android:valueTo="48"
                                android:stepSize="2" />

                            <TextView
                                android:id="@+id/txt_radius_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Bottom Margin Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_margin_bottom"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_margin"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0"
                                android:valueTo="50"
                                android:stepSize="2" />

                            <TextView
                                android:id="@+id/txt_margin_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Horizontal Margin Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_margin_horizontal"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_margin_horizontal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0"
                                android:valueTo="32"
                                android:stepSize="2" />

                            <TextView
                                android:id="@+id/txt_margin_horizontal_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- FAB Offset Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_fab_offset"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_fab"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="40"
                                android:valueTo="120"
                                android:stepSize="4" />

                            <TextView
                                android:id="@+id/txt_fab_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Glass Opacity Slider -->
                        <LinearLayout
                            android:id="@+id/layout_glass_opacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/floating_bottom_bar_glass_opacity"
                                android:textAppearance="?attr/textAppearanceTitleSmall"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/slider_opacity"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:valueFrom="10"
                                    android:valueTo="100"
                                    android:stepSize="5" />

                                <TextView
                                    android:id="@+id/txt_opacity_val"
                                    android:layout_width="48dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="end"
                                    android:textAppearance="?attr/textAppearanceBodyMedium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                        <!-- Menu Icon Size Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_icon_size"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_icon_size"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="16"
                                android:valueTo="32"
                                android:stepSize="1" />

                            <TextView
                                android:id="@+id/txt_icon_size_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Menu Label Text Size Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_text_size"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_text_size"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="10"
                                android:valueTo="16"
                                android:stepSize="1" />

                            <TextView
                                android:id="@+id/txt_text_size_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Pill Vertical Padding Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_padding_vertical"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_padding_vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0"
                                android:valueTo="20"
                                android:stepSize="1" />

                            <TextView
                                android:id="@+id/txt_padding_vertical_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Icon-Label Spacing Slider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/floating_bottom_bar_icon_label_spacing"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_icon_label_spacing"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="0"
                                android:valueTo="12"
                                android:stepSize="1" />

                            <TextView
                                android:id="@+id/txt_icon_label_spacing_val"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

        <!-- Live Preview Area -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="270dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0b141a">

                <!-- Mock WhatsApp Header Bar -->
                <LinearLayout
                    android:id="@+id/preview_header"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="#121b22"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="WhatsApp"
                        android:textColor="#e9edef"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/camera"
                        app:tint="#8696a0" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="#8696a0" />
                </LinearLayout>

                <!-- Mock Chat List & Warning Note -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@id/preview_header"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Concept Disclaimer Note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#182229"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ℹ️ Concept preview. Final margins, system navigation bar padding, and FAB vertical spacing may vary slightly depending on your device screen and settings."
                            android:textColor="#8696a0"
                            android:textSize="10sp"
                            android:lineSpacingMultiplier="1.1" />
                    </LinearLayout>

                    <!-- Chat Row 1 -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mubashar Hussain"
                                android:textColor="#e9edef"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Concept preview looks amazing! 🔥"
                                android:textColor="#8696a0"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="11:42 AM"
                            android:textColor="#8696a0"
                            android:textSize="10sp" />
                    </RelativeLayout>
                </LinearLayout>

                        <!-- Mock Floating Action Button (FAB) -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/preview_fab"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginEnd="16dp"
                            android:layout_marginBottom="90dp"
                            app:cardBackgroundColor="#00a884"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:strokeWidth="0dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_fab_new_chat"
                                app:tint="#111b21" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Floating bottom pill bar container wrapper -->
                        <FrameLayout
                            android:id="@+id/preview_pill_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true">

                            <LinearLayout
                                android:id="@+id/preview_bottom_bar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="16dp"
                                android:layout_marginBottom="22dp"
                                android:elevation="6dp"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:paddingVertical="6dp">

                                <!-- Mock Tab Items inside Pill -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <FrameLayout
                                        android:id="@+id/preview_active_indicator"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="20dp"
                                        android:background="@drawable/wa_active_indicator">

                                        <ImageView
                                            android:id="@+id/preview_chats_icon"
                                            android:layout_width="22dp"
                                            android:layout_height="22dp"
                                            android:src="@drawable/ic_tab_chats"
                                            app:tint="#00a884" />
                                    </FrameLayout>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="0dp"
                                        android:text="Chats"
                                        android:textColor="#e9edef"
                                        android:textSize="10sp"
                                        android:fontFamily="sans-serif-medium" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:src="@drawable/ic_tab_updates"
                                        app:tint="#8696a0" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="0dp"
                                        android:text="Updates"
                                        android:textColor="#8696a0"
                                        android:textSize="10sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:src="@drawable/ic_tab_communities"
                                        app:tint="#8696a0" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="0dp"
                                        android:text="Communities"
                                        android:textColor="#8696a0"
                                        android:textSize="10sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:src="@drawable/ic_tab_calls"
                                        app:tint="#8696a0" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="0dp"
                                        android:text="Calls"
                                        android:textColor="#8696a0"
                                        android:textSize="10sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
