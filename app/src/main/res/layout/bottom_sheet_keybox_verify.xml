<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/drag_handle_bg" />

    <!-- Title and Top Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/kb_status_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_round_check_circle_24"
            app:tint="?attr/colorPrimary"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/kb_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KeyBox Verification"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/kb_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking cryptographic credentials..."
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Parse Status / Error Info (Shown only if parse fails) -->
            <LinearLayout
                android:id="@+id/kb_parse_error_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:backgroundTint="#11FF3B30"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="12dp">
                
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="XML Parse Error"
                    android:textStyle="bold"
                    android:textColor="#FF3B30"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />
                
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/kb_parse_error_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/kb_details_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Bootloader Spoofer Hook card -->
                <LinearLayout
                    android:id="@+id/kb_spoofer_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_spoofer_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bootloader Spoofer Hook"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <ProgressBar
                            android:id="@+id/kb_spoofer_loading"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="16dp"
                            android:layout_height="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kb_spoofer_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <!-- Active Check Status -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_spoofer_active_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_spoofer_active_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hook Status"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Verified Boot Attestation check -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/kb_spoofer_attestation_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_spoofer_attestation_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Attestation Status"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- EC Chain attestation card -->
                <LinearLayout
                    android:id="@+id/kb_ec_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_ec_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="EC Attestation Chain (ECDSA)"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <ProgressBar
                            android:id="@+id/kb_ec_loading"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="16dp"
                            android:layout_height="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kb_ec_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <!-- Status -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_ec_status_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_ec_status_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Valid"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Not After / Expiration -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_ec_expiry_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_update_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_ec_expiry_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Expires on: 2026-06-12"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Trust Chain -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_ec_chain_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_ec_chain_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Trust Chain Verified"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Key Match -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/kb_ec_match_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_ec_match_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Private key matches public key"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- RSA Chain attestation card -->
                <LinearLayout
                    android:id="@+id/kb_rsa_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_rsa_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RSA Attestation Chain"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <ProgressBar
                            android:id="@+id/kb_rsa_loading"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="16dp"
                            android:layout_height="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kb_rsa_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <!-- Status -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_rsa_status_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_rsa_status_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Valid"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Not After / Expiration -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_rsa_expiry_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_update_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_rsa_expiry_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Expires on: 2026-06-12"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Trust Chain -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_rsa_chain_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_rsa_chain_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Trust Chain Verified"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Key Match -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/kb_rsa_match_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_rsa_match_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Private key matches public key"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Play Integrity Capability card -->
                <LinearLayout
                    android:id="@+id/kb_integrity_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_integrity_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Play Integrity Estimation"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <ProgressBar
                            android:id="@+id/kb_integrity_loading"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="16dp"
                            android:layout_height="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/kb_integrity_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <!-- Basic Integrity -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView
                                android:id="@+id/kb_basic_integrity_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_basic_integrity_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="MEETS_BASIC_INTEGRITY: Supported"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                        <!-- Device Integrity -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/kb_device_integrity_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_round_check_circle_24"
                                app:tint="#4CAF50"
                                android:layout_marginEnd="8dp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/kb_device_integrity_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="MEETS_DEVICE_INTEGRITY: Supported"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Recommendation / Verdict Card -->
                <LinearLayout
                    android:id="@+id/kb_recommendation_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_verdict_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Final Recommendation"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/kb_score_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80 / 100"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"
                            android:textAppearance="?attr/textAppearanceTitleMedium" />
                    </LinearLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/kb_recommendation_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- OK Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/bs_ok_btn"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        android:text="@android:string/ok"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>
